{
  "name": "a11yhawk",
  "version": "0.1.3",
  "description": "Open-source, self-hostable web accessibility scan engine: Playwright capture, Lighthouse audits, and BYOK LLM analysis producing structured WCAG reports.",
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "lighthouse",
    "playwright",
    "scanner",
    "audit",
    "ci"
  ],
  "license": "Apache-2.0",
  "author": "Charles Jones",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "a11yhawk": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "verify": "npm run lint && npm run typecheck && npm run test:run && npm run build",
    "prepublishOnly": "npm run verify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charlesjones-dev/a11yhawk.git"
  },
  "homepage": "https://github.com/charlesjones-dev/a11yhawk#readme",
  "bugs": {
    "url": "https://github.com/charlesjones-dev/a11yhawk/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "lighthouse": "^13.4.0",
    "openai": "^4.104.0",
    "playwright": "~1.57.0",
    "sharp": "^0.34.5"
  }
}
